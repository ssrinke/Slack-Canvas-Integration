# Slack app credentials (from api.slack.com/apps -> Basic Information / OAuth)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token   # only needed if SOCKET_MODE=true

# dnd:write/dnd:read are USER token scopes, not bot scopes -- Slack only lets
# a person silence their own notifications, not a bot on their behalf.
# Grab this from OAuth & Permissions -> "User OAuth Token" (starts with xoxp-)
# after installing the app with the user-scoped dnd:write/dnd:read added.
SLACK_USER_TOKEN=xoxp-your-user-token

# Use Socket Mode for local hackathon dev (no public URL needed)
SOCKET_MODE=true
PORT=3000

# Optional: enables the LLM urgency classifier layer (build order step 4)
ANTHROPIC_API_KEY=
ENABLE_LLM_CLASSIFIER=false
